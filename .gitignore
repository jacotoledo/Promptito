# ==========================================
# Promptito .gitignore
# Best practices for Go projects
# ==========================================

# ==== Go Build Artifacts ====
bin/
build/
dist/
vendor/

# Compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
promptito
promptito.exe

# Test binaries
*.test
*.out

# Coverage reports
coverage.out
coverage.html

# ==== IDE and Editor ====
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-*

# ==== OS Files ====
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable
Desktop.ini

# ==== Temp Files ====
*.tmp
*.temp
*.log
*.log.*
logs/
*.bak
*.backup
*.old
*.swp
~*

# ==== Cache ====
.cache/
.cache/
.npm/
.eslintcache
.parcel-cache/

# ==== Environment ====
.env
.env.local
.env.*.local
.env.development
.env.production
*.pem
*.key

# ==== Secrets (belt and suspenders) ====
*secret*
*password*
*.credentials
credentials.json

# ==== Notes (private) ====
Memory.md
*.notes
NOTES.md

# ==== Git ===
.git/
.gitignore should NOT be ignored
*.gitkeep

# ==== Misc ====
node_modules/
__pycache__/
*.pyc
*.pyo
